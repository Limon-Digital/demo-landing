---
---
<section class="hero-wrap">
  <div class="hero">
    <div class="hero-text">
      <div class="hero-label">Presencia digital para tu negocio</div>
      <h1>Tu negocio<br>merece una<br><em>web que vende</em></h1>
      <p>Creamos landing pages rápidas, modernas y efectivas para PYMEs y emprendedores. Listas para funcionar desde el día uno.</p>
      <div class="hero-ctas">
        <a href="#precios" class="btn-primary">Ver planes →</a>
        <a href="#servicios" class="btn-outline">Ver servicios</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="card card-main">
            <div class="dot"></div>
            <div class="card-title">Tu sitio en 3 pasos</div>
            <div class="card-sub">Desde el briefing hasta el lanzamiento</div>
            <div class="steps">
              <div class="step">
                <div class="step-num">01</div>
                <div class="step-info">
                  <div class="step-name">Briefing</div>
                  <div class="step-desc">Nos cuentas de tu negocio y qué necesitas</div>
                </div>
                <div class="step-check done">✓</div>
              </div>
              <div class="step-line"></div>
              <div class="step">
                <div class="step-num">02</div>
                <div class="step-info">
                  <div class="step-name">Diseño y desarrollo</div>
                  <div class="step-desc">Creamos tu landing personalizada</div>
                </div>
                <div class="step-check done">✓</div>
              </div>
              <div class="step-line"></div>
              <div class="step">
                <div class="step-num">03</div>
                <div class="step-info">
                  <div class="step-name">Entrega live</div>
                  <div class="step-desc">Tu sitio publicado y funcionando</div>
                </div>
                <div class="step-check active">→</div>
              </div>
            </div>
            <div class="card-footer">
              <div class="cf-item"><span>7d</span><p>Entrega promedio</p></div>
              <div class="cf-div"></div>
              <div class="cf-item"><span>100%</span><p>Soporte incluido</p></div>
            </div>
          </div>
    </div>
  </div>
</section>
<script>
  // Animación de entrada del hero
  const heroText = document.querySelector('.hero-text') as HTMLElement;
  const heroVisual = document.querySelector('.hero-visual') as HTMLElement;

  if (heroText) {
    heroText.style.opacity = '0';
    heroText.style.transform = 'translateY(32px)';
    heroText.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
  }
  if (heroVisual) {
    heroVisual.style.opacity = '0';
    heroVisual.style.transform = 'translateY(24px)';
    heroVisual.style.transition = 'opacity 0.7s ease 0.2s, transform 0.7s ease 0.2s';
  }

  window.addEventListener('load', () => {
    setTimeout(() => {
      if (heroText) { heroText.style.opacity = '1'; heroText.style.transform = 'translateY(0)'; }
      if (heroVisual) { heroVisual.style.opacity = '1'; heroVisual.style.transform = 'translateY(0)'; }
    }, 100);
  });
</script>
<style>
  .hero-wrap { width: 100%; }
  .hero { max-width: 1400px; margin: 0 auto; padding: 100px 48px 80px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; min-height: 88vh; }
  .hero-label { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--limon); margin-bottom: 24px; }
  .hero-label::before { content: ''; display: block; width: 24px; height: 1px; background: var(--limon); }
  h1 { font-family: var(--font-display); font-size: 56px; font-weight: 800; line-height: 1.05; letter-spacing: -2px; margin-bottom: 24px; }
  h1 em { font-style: normal; color: var(--limon); }
  .hero-text p { font-size: 16px; color: rgba(255,255,255,0.5); font-weight: 300; line-height: 1.8; max-width: 440px; margin-bottom: 36px; }
  .hero-ctas { display: flex; gap: 12px; align-items: center; margin-bottom: 48px; flex-wrap: wrap; }
  .btn-primary { background: var(--limon); color: var(--dark); padding: 12px 24px; border-radius: 6px; font-weight: 500; font-size: 14px; text-decoration: none; transition: opacity 0.2s, transform 0.15s; }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-outline { background: transparent; color: var(--white); border: 1px solid rgba(255,255,255,0.25); padding: 12px 24px; border-radius: 6px; font-size: 14px; text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .btn-outline:hover { border-color: var(--limon); color: var(--limon); }
  .hero-stats { display: flex; align-items: center; gap: 20px; }
  .stat span { font-family: var(--font-display); font-size: 24px; font-weight: 800; color: var(--limon); display: block; }
  .stat p { font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 2px; }
  .stat-div { width: 1px; height: 36px; background: rgba(255,255,255,0.1); }
  .hero-visual { position: relative; height: 400px; display: flex; align-items: center; justify-content: center; }
  .card { background: var(--dark2); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 28px; width: 280px; position: absolute; }
  .card-main { top: 20px; left: 0; z-index: 2; border-color: rgba(196,229,56,0.2); }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--limon); box-shadow: 0 0 12px var(--limon); margin-bottom: 16px; }
  .card-title { font-family: var(--font-display); font-size: 14px; font-weight: 700; margin-bottom: 6px; }
  .card-sub { font-size: 12px; color: rgba(255,255,255,0.4); margin-bottom: 16px; }
  .bars { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
  .bar { height: 3px; border-radius: 2px; background: rgba(255,255,255,0.08); overflow: hidden; }
  .fill { height: 100%; border-radius: 2px; background: var(--limon); }
  .card-stats { display: flex; gap: 20px; }
  .sv { font-family: var(--font-display); font-size: 20px; font-weight: 800; color: var(--limon); }
  .sl { font-size: 10px; color: rgba(255,255,255,0.4); margin-top: 2px; }
  .card-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .card-tags span { background: rgba(196,229,56,0.12); border-radius: 6px; padding: 5px 10px; font-size: 11px; color: var(--limon); }

  .steps { display: flex; flex-direction: column; gap: 0; margin-top: 4px; }
  .step { display: flex; align-items: center; gap: 12px; padding: 10px 0; }
  .step-num { font-family: var(--font-display); font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.25); min-width: 20px; }
  .step-info { flex: 1; }
  .step-name { font-size: 13px; font-weight: 600; color: var(--white); margin-bottom: 2px; }
  .step-desc { font-size: 11px; color: rgba(255,255,255,0.35); line-height: 1.4; }
  .step-check { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; }
  .step-check.done { background: rgba(196,229,56,0.15); color: var(--limon); }
  .step-check.active { background: var(--limon); color: var(--dark); }
  .step-line { height: 1px; background: rgba(255,255,255,0.06); margin: 0 0 0 32px; }
  .card-footer { display: flex; align-items: center; gap: 16px; margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.06); }
  .cf-item span { font-family: var(--font-display); font-size: 18px; font-weight: 800; color: var(--limon); display: block; }
  .cf-item p { font-size: 10px; color: rgba(255,255,255,0.35); margin-top: 2px; }
  .cf-div { width: 1px; height: 32px; background: rgba(255,255,255,0.08); }


  @media (max-width: 768px) {
  .hero { grid-template-columns: 1fr; padding: 60px 24px 40px; min-height: auto; gap: 40px; }
  h1 { font-size: 38px; letter-spacing: -1px; }
  .hero-visual {
    height: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
  }
  .card {
    position: relative;
    width: 100%;
    top: auto;
    bottom: auto;
    left: auto;
    right: auto;
  }
  .card-main { z-index: 2; }
  .card-secondary { z-index: 1; }
}
</style>
