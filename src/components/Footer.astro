<footer class="footer">
  <div class="logo"><span>LIMÓN</span> DIGITAL</div>
  <p>© 2025 Limón Digital SpA · Valparaíso, Chile</p>
  <div class="links">
    <a href="#">Privacidad</a>
    <a href="#">Términos</a>
    <a href="#">Instagram</a>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 32px 48px; display: flex; justify-content: space-between; align-items: center; }
  .logo { font-family: var(--font-display); font-weight: 400; font-size: 20px; letter-spacing: -0.5px; margin-bottom: 12px; }
  .logo span { color: var(--limon); font-weight: 800; }
  p { font-size: 12px; color: rgba(255,255,255,0.25); }
  .links { display: flex; gap: 24px; }
  .links a { font-size: 12px; color: rgba(255,255,255,0.25); text-decoration: none; transition: color 0.2s; }
  .links a:hover { color: var(--limon); }
  @media (max-width: 768px) {
  .footer { flex-direction: column; gap: 16px; padding: 24px; text-align: center; }
  }
</style>
