---
const links = [
  { label: 'Servicios', href: '#servicios' },
  { label: '¿Por qué nosotros?', href: '#por-que' },
  { label: 'Precios', href: '#precios' },
  { label: 'Nosotros', href: '#nosotros' },
];
---
<nav class="ld-nav">
  <a href="/" class="logo"><span>LIMÓN</span> DIGITAL</a>
  <div class="ld-nav-links" id="nav-links">
    {links.map(l => <a href={l.href}>{l.label}</a>)}
    <a href="#contacto" class="btn-primary">Cotizar proyecto</a>
  </div>
  <button class="hamburger" id="hamburger" aria-label="Abrir menú">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<script>
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('nav-links');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    btn.classList.toggle('active');
    btn.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
  });

  // Cierra el menú al hacer click en un link
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('open');
      btn?.classList.remove('active');
    });
  });
</script>

<style>
  .ld-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 48px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: sticky;
    top: 0;
    background: rgba(47,47,47,0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
  }
  .logo {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 20px;
    letter-spacing: -0.5px;
    text-decoration: none;
    color: var(--white);
  }
  .logo span { color: var(--limon); font-weight: 800; }
  .ld-nav-links {
    display: flex;
    gap: 32px;
    align-items: center;
  }
  .ld-nav-links a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s;
  }
  .ld-nav-links a:hover { color: var(--white); }
  .btn-primary {
    background: var(--limon) !important;
    color: var(--dark) !important;
    padding: 9px 20px;
    border-radius: 6px;
    font-weight: 500;
    font-size: 13px;
    transition: opacity 0.2s, transform 0.15s;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 101;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }
  /* Animación X al abrir */
  .hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 768px) {
    .ld-nav { padding: 16px 24px; }

    .hamburger { display: flex; }

    .ld-nav-links {
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(30,30,30,0.98);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      padding: 16px 24px 24px;
    }
    .ld-nav-links.open { display: flex; }
    .ld-nav-links a {
      width: 100%;
      padding: 14px 0;
      font-size: 15px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .ld-nav-links a:last-child { border-bottom: none; }
    .btn-primary {
      margin-top: 8px;
      width: 100%;
      text-align: center;
      padding: 12px 20px !important;
    }
  }
</style>