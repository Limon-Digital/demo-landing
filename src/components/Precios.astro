---
const planes = [
  {
    nombre: 'Emprende',
    precio: '149.800',
    periodo: 'pago único (IVA incluido)',
    mantencion: '+ $29.750/mes mantención',
    features: [
      'Landing 1 a 2 secciones',
      'Hero + llamada a la acción',
      'Formulario de contacto',
      'Responsive mobile',
      'Hosting incluido',
      'Soporte ticket 48 h',
    ],
    destacado: false,
    cta: 'Empezar →',
  },
  {
    nombre: 'Emprende Pro',
    precio: '357.000',
    periodo: 'pago único (IVA incluido)',
    mantencion: '+ $59.500/mes mantención',
    features: [
      'Landing completa 5 secciones',
      'Hero, servicios, sobre nosotros',
      'Galería / portafolio',
      'Testimonios + contacto',
      'SEO básico on-page',
      'Responsive mobile',
      'Soporte ticket 24 h',
    ],
    destacado: true,
    cta: 'Empezar →',
  },
  {
    nombre: 'Corporativo',
    precio: null,
    periodo: 'desde $595.000 (IVA incluido)',
    mantencion: '+ $119.000/mes mantención',
    features: [
      'Sin límite de secciones',
      'Animaciones / interactividad',
      'Integraciones y formularios',
      'Blog / CMS opcional',
      'SEO técnico',
      'Soporte prioritario mismo día',
    ],
    destacado: false,
    cta: 'Conversemos →',
  },
];
---
<section id="precios" class="section">
  <div class="inner">
    <span class="label">Planes</span>
    <h2>Simple, transparente,<br>sin sorpresas</h2>
    <p class="sub">Elige el plan que se ajusta a tu etapa. Todos incluyen dominio, SSL y hosting.</p>
    <div class="grid">
      {planes.map(p => (
        <div class={p.destacado ? 'card featured' : 'card'}>
          {p.destacado && <div class="badge">Más popular</div>}
          <div class="nombre">{p.nombre}</div>
          {p.precio
            ? <div class="precio"><span>$</span>{p.precio}</div>
            : <div class="precio" style="font-size:32px">A medida</div>
          }
          <div class="periodo">{p.periodo}</div>
          <div class="mantencion">{p.mantencion}</div>
          <ul class="features">
            {p.features.map(f => <li>{f}</li>)}
          </ul>
          <a href="#contacto" class={p.destacado ? 'btn btn-primary' : 'btn btn-outline'}>{p.cta}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section { padding: 80px 48px; border-top: 1px solid rgba(255,255,255,0.06); }
  .inner { max-width: 1400px; margin: 0 auto; }
  .label { font-size: 11px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--limon); display: block; margin-bottom: 16px; }
  h2 { font-family: var(--font-display); font-size: 38px; font-weight: 800; letter-spacing: -1.2px; line-height: 1.1; margin-bottom: 16px; }
  .sub { font-size: 15px; color: rgba(255,255,255,0.5); font-weight: 300; max-width: 480px; line-height: 1.8; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 52px; }
  .card { background: #1a1a1a; border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 32px 28px; position: relative; transition: border-color 0.2s; }
  .card:hover { border-color: rgba(196,229,56,0.3); }
  .card.featured { border-color: var(--limon); background: rgba(196,229,56,0.04); }
  .badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--limon); color: var(--dark); font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; white-space: nowrap; }
  .nombre { font-family: var(--font-display); font-size: 13px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 16px; }
  .precio { font-family: var(--font-display); font-size: 42px; font-weight: 800; letter-spacing: -2px; line-height: 1; margin-bottom: 4px; }
  .precio span { font-size: 18px; font-weight: 400; letter-spacing: 0; vertical-align: super; margin-right: 2px; }
  .periodo { font-size: 12px; color: rgba(255,255,255,0.35); margin-bottom: 24px; }
  .features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
  .features li { font-size: 13px; color: rgba(255,255,255,0.55); display: flex; gap: 8px; align-items: center; }
  .features li::before { content: '✓'; color: var(--limon); font-weight: 700; font-size: 12px; }
  .btn { display: block; width: 100%; text-align: center; padding: 12px; border-radius: 6px; font-size: 13px; font-weight: 500; text-decoration: none; transition: opacity 0.2s; }
  .btn-primary { background: var(--limon); color: var(--dark); }
  .btn-primary:hover { opacity: 0.88; }
  .btn-outline { background: transparent; color: var(--white); border: 1px solid rgba(255,255,255,0.25); }
  .btn-outline:hover { border-color: var(--limon); color: var(--limon); }
  @media (max-width: 768px) {
  .section { padding: 60px 24px; }
  .grid { grid-template-columns: 1fr; }
  .mantencion { font-size: 11px; color: rgba(255,255,255,0.25); margin-bottom: 24px; margin-top: -18px; }
  h2 { font-size: 28px; }
  }
</style>
