---
const stats = [
  { val: '7d', desc: 'Tiempo promedio de entrega de una landing completa' },
  { val: '100%', desc: 'Proyectos entregados con soporte post-lanzamiento' },
  { val: 'AI', desc: 'Cada proyecto potenciado con inteligencia artificial desde el día uno' },
];
const valores = ['✦ Innovación constante', '✦ Trabajo remoto', '✦ Enfoque en resultados', '✦ Trato cercano'];
---
<section id="nosotros" class="section">
  <div class="inner">
    <div class="texto">
      <span class="label">Sobre nosotros</span>
      <h2>Un equipo pequeño<br>con visión grande</h2>
      <p>Somos <strong>Limón Digital</strong>, una empresa constituida en Valparaíso con una filosofía clara: <strong>AI First, Remote First</strong>.</p>
      <p>Creemos que las PYMEs y emprendedores merecen acceso a tecnología de calidad, sin pagar precios de agencia ni esperar meses para tener resultados.</p>
      <div class="valores">
        {valores.map(v => <div class="pill">{v}</div>)}
      </div>
    </div>
    <div class="stats">
      {stats.map(s => (
        <div class="stat">
          <div class="val">{s.val}</div>
          <div class="desc">{s.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section { padding: 80px 48px; background: #1a1a1a; border-top: 1px solid rgba(255,255,255,0.06); }
  .inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .label { font-size: 11px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--limon); display: block; margin-bottom: 16px; }
  h2 { font-family: var(--font-display); font-size: 38px; font-weight: 800; letter-spacing: -1.2px; line-height: 1.1; margin-bottom: 20px; }
  .texto p { font-size: 15px; color: rgba(255,255,255,0.5); font-weight: 300; line-height: 1.9; margin-bottom: 16px; }
  .texto strong { color: var(--white); font-weight: 400; }
  .valores { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 28px; }
  .pill { background: rgba(196,229,56,0.07); border: 1px solid rgba(196,229,56,0.15); border-radius: 8px; padding: 12px 16px; font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.7); }
  .stats { display: flex; flex-direction: column; gap: 16px; }
  .stat { background: var(--dark); border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 24px; display: flex; align-items: center; gap: 20px; }
  .val { font-family: var(--font-display); font-size: 36px; font-weight: 800; color: var(--limon); min-width: 80px; letter-spacing: -1px; }
  .desc { font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.5; }
</style>
