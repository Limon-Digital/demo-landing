---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Limón Digital — Landing pages para PYMEs',
  description = 'Creamos landing pages rápidas, modernas y efectivas para PYMEs y emprendedores.'
} = Astro.props;

// Google Analytics — reemplaza con el ID del cliente (ej: G-XXXXXXXXXX)
const GA_ID = '';
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>