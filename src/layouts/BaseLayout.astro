---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Limón Digital — Landing pages para PYMEs',
  description = 'Creamos landing pages rápidas, modernas y efectivas para PYMEs y emprendedores.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
